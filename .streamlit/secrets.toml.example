# Copy to .streamlit/secrets.toml locally, or paste into
# Streamlit Cloud -> App -> Settings -> Secrets.  NEVER commit real secrets.

# Supabase Postgres (manual §6). Without this the app runs on temporary
# SQLite and data is lost on every redeploy.
DATABASE_URL = "postgresql://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

[smtp]                      # email notifications + reminders (manual §9)
host = "smtp.office365.com" # or smtp.gmail.com with an App Password
port = 587
user = "hr-noreply@yourdomain.com"
password = "app-password-here"
from = "AMS HR System <hr-noreply@yourdomain.com>"
app_url = "https://anca-hr-reporting.streamlit.app"

[car_booking]               # manual §10
apps_script_url = "https://script.google.com/macros/s/XXXX/exec"
jira_board_url = "https://ancagroup.atlassian.net/jira/core/projects/AHA/board"

# ---- LINE Messaging API (@529aaynp) — approval & driver notifications ----
# Channel access token: LINE Developers Console -> your channel ->
# Messaging API tab -> Channel access token (long-lived) -> Issue.
# Recipients: link each user's LINE userId in System Admin -> Users, and
# each driver's in Car Booking -> Admin -> Drivers. Without this section
# the app still works — LINE pushes are skipped gracefully.
[line]
token = "PASTE_CHANNEL_ACCESS_TOKEN"
